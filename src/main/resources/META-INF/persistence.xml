<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="2.1" xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_1.xsd">
    <persistence-unit name="BW_backendpu">
        <!--    lista delle classi -->
        <class>entities.Utente</class>
        <class>entities.Mezzo</class>
        <class>Enum.TipoMezzo</class>
        <class>Enum.StatoMezzo</class>
        <class>entities.Percorrenza</class>
        <class>entities.Tessera</class>
        <class>entities.TitoloDiViaggio</class>
        <class>entities.Abbonamento</class>
        <class>entities.Biglietto</class>
        <class>entities.Tratta</class>
        <class>entities.Distributore</class>
        <class>entities.Manutenzione</class>
        <class>entities.PuntoDiEmissione</class>
        <class>entities.Rivenditore</class>



        <properties>
            
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/BW_backend"/>
            <!--            nome user x acesso al DB-->
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <!--            password x accesso al DB-->
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <!--            tipo di accesso-->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit>
</persistence>